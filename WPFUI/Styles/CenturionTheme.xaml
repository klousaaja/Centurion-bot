<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Centurion Black Card Color Palette -->
    <Color x:Key="CenturionBlack">#FF0D0D0D</Color>
    <Color x:Key="CenturionSurface">#FF1B1B1B</Color>
    <Color x:Key="CenturionCard">#FF242424</Color>
    <Color x:Key="CenturionBorder">#FF3A3A3A</Color>
    <Color x:Key="CenturionGold">#FFC9A96E</Color>
    <Color x:Key="CenturionGoldBright">#FFD4AF37</Color>
    <Color x:Key="CenturionGoldMuted">#FF8B7240</Color>
    <Color x:Key="CenturionTextPrimary">#FFE8E0D0</Color>
    <Color x:Key="CenturionTextSecondary">#FF8A8A8A</Color>
    <Color x:Key="CenturionTextMuted">#FF5A5A5A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="CenturionBlackBrush" Color="{StaticResource CenturionBlack}" />
    <SolidColorBrush x:Key="CenturionSurfaceBrush" Color="{StaticResource CenturionSurface}" />
    <SolidColorBrush x:Key="CenturionCardBrush" Color="{StaticResource CenturionCard}" />
    <SolidColorBrush x:Key="CenturionBorderBrush" Color="{StaticResource CenturionBorder}" />
    <SolidColorBrush x:Key="CenturionGoldBrush" Color="{StaticResource CenturionGold}" />
    <SolidColorBrush x:Key="CenturionGoldBrightBrush" Color="{StaticResource CenturionGoldBright}" />
    <SolidColorBrush x:Key="CenturionGoldMutedBrush" Color="{StaticResource CenturionGoldMuted}" />
    <SolidColorBrush x:Key="CenturionTextPrimaryBrush" Color="{StaticResource CenturionTextPrimary}" />
    <SolidColorBrush x:Key="CenturionTextSecondaryBrush" Color="{StaticResource CenturionTextSecondary}" />
    <SolidColorBrush x:Key="CenturionTextMutedBrush" Color="{StaticResource CenturionTextMuted}" />

    <!-- Gold gradient for premium elements -->
    <LinearGradientBrush x:Key="CenturionGoldGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFB8860B" Offset="0.0" />
        <GradientStop Color="#FFD4AF37" Offset="0.4" />
        <GradientStop Color="#FFC9A96E" Offset="0.7" />
        <GradientStop Color="#FFB8860B" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Subtle surface gradient for depth -->
    <LinearGradientBrush x:Key="CenturionSurfaceGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF1E1E1E" Offset="0.0" />
        <GradientStop Color="#FF161616" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Button style overrides for luxury feel -->
    <Style x:Key="CenturionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Background" Value="{StaticResource CenturionGoldMutedBrush}" />
        <Setter Property="Foreground" Value="{StaticResource CenturionTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CenturionGoldBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="12,6" />
    </Style>

    <!-- TabControl styling -->
    <Style x:Key="CenturionTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource CenturionCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CenturionBorderBrush}" />
    </Style>

    <Style x:Key="CenturionTabItem" TargetType="TabItem">
        <Setter Property="Background" Value="{StaticResource CenturionSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource CenturionTextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CenturionBorderBrush}" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource CenturionCardBrush}" />
                <Setter Property="Foreground" Value="{StaticResource CenturionGoldBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Section header text style -->
    <Style x:Key="CenturionSectionHeader" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource CenturionGoldBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Margin" Value="0,4,0,8" />
    </Style>

    <!-- Label styling for dark theme -->
    <Style x:Key="CenturionLabel" TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource CenturionTextPrimaryBrush}" />
    </Style>

    <!-- CheckBox styling -->
    <Style x:Key="CenturionCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource CenturionTextPrimaryBrush}" />
    </Style>

    <!-- DataGrid styling -->
    <Style x:Key="CenturionDataGrid" TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource CenturionCardBrush}" />
        <Setter Property="Foreground" Value="{StaticResource CenturionTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CenturionBorderBrush}" />
        <Setter Property="RowBackground" Value="{StaticResource CenturionSurfaceBrush}" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource CenturionCardBrush}" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource CenturionBorderBrush}" />
    </Style>

    <!-- ListBox styling -->
    <Style x:Key="CenturionListBox" TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource CenturionSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource CenturionTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CenturionBorderBrush}" />
    </Style>

    <!-- TextBox styling -->
    <Style x:Key="CenturionTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource CenturionCardBrush}" />
        <Setter Property="Foreground" Value="{StaticResource CenturionTextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource CenturionGoldBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CenturionBorderBrush}" />
    </Style>

    <!-- ComboBox styling -->
    <Style x:Key="CenturionComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource CenturionCardBrush}" />
        <Setter Property="Foreground" Value="{StaticResource CenturionTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CenturionBorderBrush}" />
    </Style>

    <!-- ScrollViewer styling -->
    <Style x:Key="CenturionScrollViewer" TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent" />
    </Style>
</ResourceDictionary>
