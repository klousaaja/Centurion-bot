<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="Box" TargetType="Border">
        <Setter Property="Margin" Value="5" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="BorderBrush" Value="{DynamicResource CenturionBorderBrush}" />
        <Setter Property="Background" Value="{DynamicResource CenturionCardBrush}" />
        <Setter Property="Padding" Value="8" />
    </Style>
    <Style x:Key="Background" TargetType="Border">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Black" />
        <Setter Property="Opacity" Value=".85" />
    </Style>
    <Style x:Key="Content" TargetType="Border">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource CenturionCardBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CenturionGoldBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8,0,8,0" />
        <Setter Property="BitmapEffect">
            <Setter.Value>
                <DropShadowBitmapEffect Color="#FFC9A96E" Opacity="0.3" Direction="270" ShadowDepth="2" />
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
