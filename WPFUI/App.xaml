<Application
    x:Class="WPFUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="Amber" SecondaryColor="Brown" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
                <ResourceDictionary Source="Styles/BorderStyle.xaml" />
                <ResourceDictionary Source="Styles/ListBoxItem.xaml" />
                <ResourceDictionary Source="Styles/Dialog.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Centurion luxury dark theme overrides -->
            <SolidColorBrush x:Key="MaterialDesignPaper" Color="#0D0D0D" />
            <SolidColorBrush x:Key="MaterialDesignCardBackground" Color="#242424" />
            <SolidColorBrush x:Key="MaterialDesignBody" Color="#E8E0D0" />
            <SolidColorBrush x:Key="MaterialDesignBodyLight" Color="#B8B0A0" />

            <!-- Primary accent: Luxury gold -->
            <SolidColorBrush x:Key="PrimaryHueLightBrush" Color="#C9A96E" />
            <SolidColorBrush x:Key="PrimaryHueLightForegroundBrush" Color="#0D0D0D" />
            <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="#8B7240" />
            <SolidColorBrush x:Key="PrimaryHueMidForegroundBrush" Color="#E8E0D0" />
            <SolidColorBrush x:Key="PrimaryHueDarkBrush" Color="#6B5630" />
            <SolidColorBrush x:Key="PrimaryHueDarkForegroundBrush" Color="#E8E0D0" />

            <!-- Secondary accent: Warm brown -->
            <SolidColorBrush x:Key="SecondaryHueLightBrush" Color="#A0845C" />
            <SolidColorBrush x:Key="SecondaryHueMidBrush" Color="#7B5B3A" />
            <SolidColorBrush x:Key="SecondaryHueDarkBrush" Color="#5C3D20" />
        </ResourceDictionary>
    </Application.Resources>
</Application>